{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent",
  "type": "object",
  "description": "An agent recipient who can designate a recipient to sign in their place.",
  "properties": {
    "recipientId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "routingOrder": {
      "type": "string"
    },
    "status": {
      "type": "string"
    }
  }
}