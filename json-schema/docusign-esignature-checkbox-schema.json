{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Checkbox",
  "type": "object",
  "description": "A checkbox tab for boolean selection.",
  "properties": {
    "tabId": {
      "type": "string"
    },
    "tabLabel": {
      "type": "string"
    },
    "documentId": {
      "type": "string"
    },
    "pageNumber": {
      "type": "string"
    },
    "recipientId": {
      "type": "string"
    },
    "xPosition": {
      "type": "string"
    },
    "yPosition": {
      "type": "string"
    },
    "anchorString": {
      "type": "string"
    },
    "selected": {
      "type": "string",
      "description": "When true, the checkbox is selected."
    },
    "required": {
      "type": "string"
    },
    "locked": {
      "type": "string"
    }
  }
}