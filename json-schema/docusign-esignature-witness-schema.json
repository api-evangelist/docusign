{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Witness",
  "type": "object",
  "description": "A witness recipient who verifies the identity of a signer.",
  "properties": {
    "recipientId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "routingOrder": {
      "type": "string"
    },
    "status": {
      "type": "string"
    }
  }
}