{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FormulaTab",
  "type": "object",
  "description": "A calculated field tab using formulas.",
  "properties": {
    "tabId": {
      "type": "string"
    },
    "tabLabel": {
      "type": "string"
    },
    "documentId": {
      "type": "string"
    },
    "pageNumber": {
      "type": "string"
    },
    "recipientId": {
      "type": "string"
    },
    "xPosition": {
      "type": "string"
    },
    "yPosition": {
      "type": "string"
    },
    "formula": {
      "type": "string",
      "description": "The formula expression."
    },
    "roundDecimalPlaces": {
      "type": "string"
    },
    "value": {
      "type": "string"
    }
  }
}