{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CertifiedDelivery",
  "type": "object",
  "description": "A certified delivery recipient who must confirm receipt of the envelope documents.",
  "properties": {
    "recipientId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "routingOrder": {
      "type": "string"
    },
    "status": {
      "type": "string"
    }
  }
}