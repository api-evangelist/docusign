{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RadioGroup",
  "type": "object",
  "description": "A group of radio buttons for single-choice selection.",
  "properties": {
    "groupName": {
      "type": "string",
      "description": "The name of the radio group."
    },
    "documentId": {
      "type": "string"
    },
    "recipientId": {
      "type": "string"
    },
    "radios": {
      "type": "array"
    },
    "required": {
      "type": "string"
    }
  }
}