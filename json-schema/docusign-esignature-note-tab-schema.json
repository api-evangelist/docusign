{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NoteTab",
  "type": "object",
  "description": "A read-only note tab for displaying text.",
  "properties": {
    "tabId": {
      "type": "string"
    },
    "tabLabel": {
      "type": "string"
    },
    "documentId": {
      "type": "string"
    },
    "pageNumber": {
      "type": "string"
    },
    "recipientId": {
      "type": "string"
    },
    "xPosition": {
      "type": "string"
    },
    "yPosition": {
      "type": "string"
    },
    "value": {
      "type": "string"
    }
  }
}