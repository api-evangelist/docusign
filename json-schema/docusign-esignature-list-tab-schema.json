{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ListTab",
  "type": "object",
  "description": "A dropdown list tab for selecting from predefined options.",
  "properties": {
    "tabId": {
      "type": "string"
    },
    "tabLabel": {
      "type": "string"
    },
    "documentId": {
      "type": "string"
    },
    "pageNumber": {
      "type": "string"
    },
    "recipientId": {
      "type": "string"
    },
    "xPosition": {
      "type": "string"
    },
    "yPosition": {
      "type": "string"
    },
    "anchorString": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "listItems": {
      "type": "array"
    },
    "required": {
      "type": "string"
    }
  }
}