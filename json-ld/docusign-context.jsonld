        },
        "tabLabel": {
          "@id": "docusign:tabLabel",
          "@type": "xsd:string"
        },
        "documentId": {
          "@id": "docusign:documentId",
          "@type": "xsd:string"
        },
        "pageNumber": {
          "@id": "docusign:pageNumber",
          "@type": "xsd:integer"
        },
        "recipientId": {
          "@id": "docusign:recipientId",
          "@type": "xsd:string"
        },
        "xPosition": {
          "@id": "docusign:xPosition",
          "@type": "xsd:integer"
        },
        "yPosition": {
          "@id": "docusign:yPosition",
          "@type": "xsd:integer"
        },
        "anchorString": {
          "@id": "docusign:anchorString",
          "@type": "xsd:string"
        },
        "value": {
          "@id": "schema:value",
          "@type": "xsd:string"
        }
      }
    },

    "EnvelopeTemplate": {
      "@id": "docusign:EnvelopeTemplate",
      "@context": {
        "templateId": {
          "@id": "docusign:templateId",
          "@type": "xsd:string"
        },
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "created": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "lastModified": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        },
        "lastUsed": {
          "@id": "docusign:lastUsed",
          "@type": "xsd:dateTime"
        },
        "shared": {
          "@id": "docusign:shared",
          "@type": "xsd:boolean"
        },
        "owner": {
          "@id": "docusign:owner",
          "@type": "docusign:UserInfo"
        },
        "emailSubject": {
          "@id": "docusign:emailSubject",
          "@type": "xsd:string"
        },
        "documents": {
          "@id": "docusign:documents",
          "@type": "docusign:Document",
          "@container": "@set"
        },
        "recipients": {
          "@id": "docusign:recipients",
          "@type": "docusign:Recipients"
        }
      }
    },

    "Notification": {
      "@id": "docusign:Notification",
      "@context": {
        "useAccountDefaults": {
          "@id": "docusign:useAccountDefaults",
          "@type": "xsd:boolean"
        },
        "reminders": {
          "@id": "docusign:reminders",
          "@type": "docusign:ReminderSettings"
        },
        "expirations": {
          "@id": "docusign:expirations",
          "@type": "docusign:ExpirationSettings"
        }
      }
    },

    "CustomFields": {
      "@id": "docusign:CustomFields",
