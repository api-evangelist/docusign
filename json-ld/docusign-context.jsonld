          "@container": "@set"
        },
        "listCustomFields": {
          "@id": "docusign:listCustomFields",
          "@container": "@set"
        }
      }
    },

    "EventNotification": {
      "@id": "docusign:EventNotification",
      "@context": {
        "url": {
          "@id": "docusign:webhookUrl",
          "@type": "@id"
        },
        "loggingEnabled": {
          "@id": "docusign:loggingEnabled",
          "@type": "xsd:boolean"
        },
        "envelopeEvents": {
          "@id": "docusign:envelopeEvents",
          "@container": "@set"
        },
        "recipientEvents": {
          "@id": "docusign:recipientEvents",
          "@container": "@set"
        },
        "includeDocuments": {
          "@id": "docusign:includeDocuments",
          "@type": "xsd:boolean"
        },
        "includeHMAC": {
          "@id": "docusign:includeHMAC",
          "@type": "xsd:boolean"
        }
      }
    },

    "UserInfo": {
      "@id": "docusign:UserInfo",
      "@context": {
        "userName": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "email": {
          "@id": "schema:email",
          "@type": "xsd:string"
        },
        "userId": {
          "@id": "docusign:userId",
          "@type": "xsd:string"
        },
        "accountId": {
          "@id": "docusign:accountId",
          "@type": "xsd:string"
        }
      }
    },

    "ConnectEvent": {
      "@id": "docusign:ConnectEvent",
      "@context": {
        "event": {
          "@id": "docusign:eventType",
          "@type": "xsd:string"
        },
        "apiVersion": {
          "@id": "docusign:apiVersion",
          "@type": "xsd:string"
        },
        "configurationId": {
          "@id": "docusign:configurationId",
          "@type": "xsd:string"
        },
        "uri": {
          "@id": "docusign:resourceUri",
          "@type": "@id"
        },
        "retryCount": {
          "@id": "docusign:retryCount",
          "@type": "xsd:integer"
        },
        "generatedDateTime": {
          "@id": "prov:generatedAtTime",
          "@type": "xsd:dateTime"
        },
        "data": {
          "@id": "docusign:eventData",
          "@type": "docusign:ConnectEventData"
        }
      }
    },

    "ConnectEventData": {
      "@id": "docusign:ConnectEventData",
      "@context": {
        "accountId": {
          "@id": "docusign:accountId",
          "@type": "xsd:string"
        },
        "userId": {
          "@id": "docusign:userId",
          "@type": "xsd:string"
        },
        "envelopeId": {
          "@id": "docusign:envelopeId",
          "@type": "xsd:string"
        },
        "envelopeSummary": {
          "@id": "docusign:envelopeSummary",
          "@type": "docusign:Envelope"
        }
