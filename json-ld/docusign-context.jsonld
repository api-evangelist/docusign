          "@container": "@set"
        },
        "radioGroupTabs": {
          "@id": "docusign:radioGroupTabs",
          "@type": "docusign:RadioGroupTab",
          "@container": "@set"
        },
        "listTabs": {
          "@id": "docusign:listTabs",
          "@type": "docusign:ListTab",
          "@container": "@set"
        },
        "formulaTabs": {
          "@id": "docusign:formulaTabs",
          "@type": "docusign:FormulaTab",
          "@container": "@set"
        }
      }
